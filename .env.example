# ============================================================
# AI PC28 预测平台 - 环境配置文件示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 按部署环境调整配置值
# 3. .env 文件不会被提交到 git 仓库
# ============================================================

# ============ 安全配置 ============
# Flask Session 密钥（生产环境必须修改为随机字符串）
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ============ 服务器配置 ============
HOST=0.0.0.0
PORT=35008
DEBUG=False

# ============ 数据库配置 ============
DATABASE_PATH=pc28_predictor.db

# ============ PC28 数据配置 ============
PC28_API_BASE_URL=https://pc28.help
PC28_REQUEST_TIMEOUT=10
PC28_SYNC_HISTORY=120

# ============ 自动预测配置 ============
AUTO_PREDICTION=True
PREDICTION_POLL_INTERVAL=20
DEFAULT_HISTORY_WINDOW=60
DEFAULT_PREDICTION_TEMPERATURE=0.7

# ============ 日志配置 ============
LOG_LEVEL=INFO

# ============ Linux DO OAuth 配置 ============
# 申请地址：https://connect.linux.do
LINUXDO_CLIENT_ID=你的Client ID
LINUXDO_CLIENT_SECRET=你的Client Secret

# 本地开发：http://localhost:35008/api/auth/callback
# 生产环境：https://your-domain/api/auth/callback
LINUXDO_REDIRECT_URI=https://your-domain/api/auth/callback
LINUXDO_MIN_TRUST_LEVEL=1

# ============================================================
# 注意事项：
# 1. 请勿将 .env 文件提交到版本控制系统
# 2. 生产环境请使用强随机 SECRET_KEY
# 3. 如果关闭自动预测，可设置 AUTO_PREDICTION=False
# 4. 若使用反向代理，请同步校准 OAuth 回调地址
# ============================================================
